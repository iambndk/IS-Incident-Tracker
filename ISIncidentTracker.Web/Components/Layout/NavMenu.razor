<div class="sidebar @(isCollapsed ? "collapsed" : "")">
    <!-- Логотип и кнопка сворачивания -->
    <div class="sidebar-header">
        <i class="bi bi-shield-lock-fill logo-icon"></i>
        <span class="logo-text">IS Tracker</span>
        <button class="toggle-btn" @onclick="ToggleMenu">
            <i class="bi @(isCollapsed ? "bi-list" : "bi-x-lg")"></i>
        </button>
    </div>
    <div class="nav-scrollable">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-speedometer2"></i>
                <span class="link-text">Dashboard</span>
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="incidents">
                <i class="bi bi-list-check"></i>
                <span class="link-text">Инциденты</span>
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="incidents/create">
                <i class="bi bi-plus-circle-dotted"></i>
                <span class="link-text">Создать</span>
            </NavLink>
        </div>
    </div>
</div>

@code {
    private bool isCollapsed = false;
    
    [Parameter]  // ← ДОБАВИТЬ ЭТОТ АТРИБУТ!
    public EventCallback OnToggle { get; set; }

    private async Task ToggleMenu()
    {
        isCollapsed = !isCollapsed;
        await OnToggle.InvokeAsync();
    }
}