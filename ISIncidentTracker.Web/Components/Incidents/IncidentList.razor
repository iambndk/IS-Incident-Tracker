@page "/incidents"
@using ISIncidentTracker.Web.Models
@using ISIncidentTracker.Web.Models.Enums
@using ISIncidentTracker.Web.Services.Interfaces
@inject IIncidentService IncidentService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Список инцидентов</PageTitle>

<h1>Инциденты информационной безопасности</h1>

<div class="mb-3">
    <a href="/incidents/create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Создать инцидент
    </a>
</div>

@if (incidents == null)
{
    <div class="alert alert-info">Загрузка...</div>
}
else if (!incidents.Any())
{
    <div class="alert alert-warning">Инциденты не найдены</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Заголовок</th>
                    <th>Категория</th>
                    <th>Критичность</th>
                    <th>Статус</th>
                    <th>Дата регистрации</th>
                    <th>Ответственный</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var incident in incidents)
                {
                    <tr>
                        <td>@incident.Id</td>
                        <td>@incident.Title</td>
                        <td>@incident.Category?.Name</td>
                        <td>
                            <span class="badge @GetSeverityBadge(incident.Severity)">
                                @incident.Severity
                            </span>
                        </td>
                        <td>
                            <span class="badge @GetStatusBadge(incident.Status)">
                                @incident.Status
                            </span>
                        </td>
                        <td>@incident.ReportedDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@incident.AssignedTo?.FullName ?? "Не назначен"</td>
                        <td>
                            <a href="/incidents/@incident.Id" class="btn btn-sm btn-info">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="/incidents/@incident.Id/edit" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IEnumerable<Incident> incidents = new List<Incident>();

    protected override async Task OnInitializedAsync()
    {
        incidents = await IncidentService.GetAllIncidentsAsync();
    }

    private string GetSeverityBadge(IncidentSeverity severity)
    {
        return severity switch
        {
            IncidentSeverity.Low => "bg-success",
            IncidentSeverity.Medium => "bg-warning text-dark",
            IncidentSeverity.High => "bg-danger",
            IncidentSeverity.Critical => "bg-dark",
            _ => "bg-secondary"
        };
    }

    private string GetStatusBadge(IncidentStatus status)
    {
        return status switch
        {
            IncidentStatus.New => "bg-info",
            IncidentStatus.Assigned => "bg-primary",
            IncidentStatus.InProgress => "bg-warning text-dark",
            IncidentStatus.Resolved => "bg-success",
            IncidentStatus.Closed => "bg-secondary",
            IncidentStatus.Rejected => "bg-danger",
            _ => "bg-light"
        };
    }
}