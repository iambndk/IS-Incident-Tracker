@page "/incidents"
@using ISIncidentTracker.Web.Models
@using ISIncidentTracker.Web.Models.Enums
@using ISIncidentTracker.Web.Services.Interfaces
@inject IIncidentService IncidentService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Инциденты</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Инциденты информационной безопасности</h1>
    <a href="/incidents/create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Создать инцидент
    </a>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Загрузка...</span>
        </div>
        <p class="mt-2 text-muted">Загрузка инцидентов...</p>
    </div>
}
else if (incidents == null || !incidents.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Инциденты не найдены.
        <a href="/incidents/create" class="alert-link">Создайте первый инцидент</a>.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width: 60px;">ID</th>
                    <th>Название</th>
                    <th>Категория</th>
                    <th>Уровень</th>
                    <th>Статус</th>
                    <th>Дата</th>
                    <th>Ответственный</th>
                    <th style="width: 120px;">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var incident in incidents)
                {
                    <tr>
                        <td class="text-muted">@incident.Id</td>
                        <td>
                            <strong>@incident.Title</strong>
                            @if (!string.IsNullOrEmpty(incident.Description))
                            {
                                <br />
                                <small class="text-muted">@incident.Description.Substring(0, Math.Min(50, incident.Description.Length))...</small>
                            }
                        </td>
                        <td>
                            <span class="badge bg-secondary">@incident.Category?.Name</span>
                        </td>
                        <td>
                            <span class="badge @GetSeverityClass(incident.Severity)">
                                @incident.Severity
                            </span>
                        </td>
                        <td>
                            <span class="badge @GetStatusClass(incident.Status)">
                                @incident.Status
                            </span>
                        </td>
                        <td>@incident.ReportedDate.ToString("dd.MM.yyyy")</td>
                        <td>@incident.AssignedTo?.FullName</td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-info"
                                        @onclick="() => ViewIncident(incident.Id)"
                                        title="Просмотр">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button type="button" class="btn btn-warning"
                                        @onclick="() => EditIncident(incident.Id)"
                                        title="Редактировать">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button" class="btn btn-danger"
                                        @onclick="() => ConfirmDelete(incident.Id)"
                                        title="Удалить">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IEnumerable<Incident> incidents = new List<Incident>();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadIncidents();
    }

    private async Task LoadIncidents()
    {
        isLoading = true;
        StateHasChanged();
        
        try
        {
            incidents = await IncidentService.GetAllIncidentsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetSeverityClass(IncidentSeverity severity)
    {
        return severity switch
        {
            IncidentSeverity.Critical => "bg-danger",
            IncidentSeverity.High => "bg-orange",
            IncidentSeverity.Medium => "bg-warning text-dark",
            IncidentSeverity.Low => "bg-success",
            _ => "bg-secondary"
        };
    }

    private string GetStatusClass(IncidentStatus status)
    {
        return status switch
        {
            IncidentStatus.New => "bg-info",
            IncidentStatus.InProgress => "bg-warning text-dark",
            IncidentStatus.Pending => "bg-orange",
            IncidentStatus.Resolved => "bg-success",
            IncidentStatus.Closed => "bg-secondary",
            _ => "bg-light"
        };
    }

    private void ViewIncident(int id) => NavigationManager.NavigateTo($"/incidents/{id}");
    private void EditIncident(int id) => NavigationManager.NavigateTo($"/incidents/{id}/edit");
    
    private async Task ConfirmDelete(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Удалить этот инцидент?");
        if (confirmed)
        {
            await IncidentService.DeleteIncidentAsync(id);
            await LoadIncidents();
        }
    }
}