@page "/incidents/{Id:int}"
@using ISIncidentTracker.Web.Models
@using ISIncidentTracker.Web.Models.Enums
@using ISIncidentTracker.Web.Services.Interfaces
@inject IIncidentService IncidentService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Детали инцидента #@incident?.Id</PageTitle>

@if (incident == null)
{
    <div class="alert alert-info">Загрузка...</div>
}
else
{
    <h1>Инцидент #@incident.Id</h1>

    <div class="row mb-3">
        <div class="col-md-6">
            <span class="badge @GetSeverityBadge(incident.Severity) fs-6">
                @incident.Severity
            </span>
            <span class="badge @GetStatusBadge(incident.Status) fs-6 ms-2">
                @incident.Status
            </span>
        </div>
        <div class="col-md-6 text-end">
            <a href="/incidents/@incident.Id/edit" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Редактировать
            </a>
            <button @onclick="DeleteIncident" class="btn btn-danger ms-2">
                <i class="bi bi-trash"></i> Удалить
            </button>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">@incident.Title</h5>
        </div>
        <div class="card-body">
            <p>@incident.Description</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Основная информация</div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <strong>Категория:</strong> @incident.Category?.Name
                    </li>
                    <li class="list-group-item">
                        <strong>Дата регистрации:</strong>
                        @incident.ReportedDate.ToString("dd.MM.yyyy HH:mm")
                    </li>
                    <li class="list-group-item">
                        <strong>Дата возникновения:</strong>
                        @(incident.OccurredDate?.ToString("dd.MM.yyyy HH:mm") ?? "Не указана")
                    </li>
                    <li class="list-group-item">
                        <strong>Сообщил:</strong> @incident.ReportedBy?.FullName
                    </li>
                </ul>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Ответственный</div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <strong>Назначен:</strong>
                        @(incident.AssignedTo?.FullName ?? "Не назначен")
                    </li>
                    <li class="list-group-item">
                        <strong>Дата разрешения:</strong>
                        @(incident.ResolvedDate?.ToString("dd.MM.yyyy HH:mm") ?? "Не разрешен")
                    </li>
                    <li class="list-group-item">
                        <strong>Решение:</strong>
                        @(incident.Resolution ?? "Не указано")
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a href="/incidents" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Назад к списку
        </a>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Incident? incident;

    protected override async Task OnInitializedAsync()
    {
        incident = await IncidentService.GetIncidentByIdAsync(Id);
    }

    private string GetSeverityBadge(IncidentSeverity severity)
    {
        return severity switch
        {
            IncidentSeverity.Low => "bg-success",
            IncidentSeverity.Medium => "bg-warning text-dark",
            IncidentSeverity.High => "bg-danger",
            IncidentSeverity.Critical => "bg-dark",
            _ => "bg-secondary"
        };
    }

    private string GetStatusBadge(IncidentStatus status)
    {
        return status switch
        {
            IncidentStatus.New => "bg-info",
            IncidentStatus.Assigned => "bg-primary",
            IncidentStatus.InProgress => "bg-warning text-dark",
            IncidentStatus.Resolved => "bg-success",
            IncidentStatus.Closed => "bg-secondary",
            IncidentStatus.Rejected => "bg-danger",
            _ => "bg-light"
        };
    }

    private async Task DeleteIncident()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Вы уверены, что хотите удалить этот инцидент?");
        if (confirmed)
        {
            await IncidentService.DeleteIncidentAsync(incident!.Id);
            NavigationManager.NavigateTo("/incidents");
        }
    }
}