@page "/incidents/create"
@page "/incidents/{Id:int}/edit"
@using ISIncidentTracker.Web.Models
@using ISIncidentTracker.Web.Models.Enums
@using ISIncidentTracker.Web.Services
@using ISIncidentTracker.Web.Data.Repositories.Interfaces
@using ISIncidentTracker.Web.Services.Interfaces
@inject IIncidentService IncidentService
@inject IRepository<Category> CategoryRepository
@inject IRepository<User> UserRepository
@inject IncidentSeverityCalculator SeverityCalculator
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Редактирование инцидента" : "Создание инцидента")</PageTitle>

<h1 class="mb-4">@(IsEdit ? "Редактирование инцидента" : "Создание нового инцидента")</h1>

<div class="row">
    <!-- Левая часть: Форма (7 колонок) -->
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi @(IsEdit ? "bi-pencil-square" : "bi-file-earmark-plus")"></i> @(IsEdit ? "Изменение данных" : "Данные инцидента")</h5>
            </div>
            <div class="card-body">
                <EditForm Model="@incident" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="alert alert-danger" />

                    <div class="row g-3">
                        <!-- Заголовок -->
                        <div class="col-md-6">
                            <label class="form-label">Название *</label>
                            <InputText @bind-Value="incident.Title" class="form-control" placeholder="Краткая суть (напр. DDoS атака на порт 80)" />
                            <ValidationMessage For="@(() => incident.Title)" class="text-danger small" />
                        </div>

                        <!-- Категория -->
                        <div class="col-md-6">
                            <label class="form-label">Категория *</label>
                            <select @bind="incident.CategoryId"
                                    @bind:after="OnCategorySelected"
                                    class="form-select">
                                <option value="0">Выберите категорию</option>
                                @foreach (var category in categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                            <ValidationMessage For="@(() => incident.CategoryId)" class="text-danger small" />
                        </div>

                        <!-- Уровень критичности -->
                        <div class="col-md-6">
                            <label class="form-label">Уровень критичности</label>
                            <InputSelect @bind-Value="incident.Severity" class="form-select">
                                @foreach (var val in Enum.GetValues<IncidentSeverity>())
                                {
                                    <option value="@val">@val</option>
                                }
                            </InputSelect>
                            @if (showHint)
                            {
                                <div class="form-text text-success">
                                    <i class="bi bi-magic"></i> Установлено автоматически на основе категории
                                </div>
                            }
                        </div>

                        <!-- Статус -->
                        <div class="col-md-6">
                            <label class="form-label">Статус</label>
                            <InputSelect @bind-Value="incident.Status" class="form-select">
                                @foreach (var val in Enum.GetValues<IncidentStatus>())
                                {
                                    <option value="@val">@val</option>
                                }
                            </InputSelect>
                        </div>

                        <!-- Описание -->
                        <div class="col-12">
                            <label class="form-label">Описание *</label>
                            <InputTextArea @bind-Value="incident.Description" class="form-control" rows="4" placeholder="Подробности инцидента..." />
                            <ValidationMessage For="@(() => incident.Description)" class="text-danger small" />
                        </div>
                    </div>

                    <hr />
                    <h5 class="mb-3">Ответственные</h5>

                    <div class="row g-3">
                        <!-- Кто сообщил -->
                        <div class="col-md-6">
                            <label class="form-label">Кто сообщил *</label>
                            <InputSelect @bind-Value="incident.ReportedById" class="form-select">
                                <option value="0">Выберите...</option>
                                @foreach (var user in users)
                                {
                                    <option value="@user.Id">@user.FullName (@user.Role)</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => incident.ReportedById)" class="text-danger small" />
                        </div>

                        <!-- Кому назначен -->
                        <div class="col-md-6">
                            <label class="form-label">Назначить на</label>
                            <InputSelect @bind-Value="incident.AssignedToId" class="form-select">
                                <option value="">-- Не назначен --</option>
                                @foreach (var user in users)
                                {
                                    <option value="@user.Id">@user.FullName (@user.Role)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-check-lg"></i> @(IsEdit ? "Сохранить изменения" : "Создать")
                        </button>
                        <a href="/incidents" class="btn btn-outline-secondary">
                            Отмена
                        </a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <!-- Правая часть: Инструкция (5 колонок) -->
    <div class="col-md-5">
        <div class="card h-100" style="background: var(--color-gray) !important; border: 1px solid var(--color-green) !important;">
            <div class="card-body">
                <h6 class="card-title mb-3" style="color: var(--color-green) !important; text-shadow: var(--glow-text);">
                    <i class="bi bi-lightbulb"></i> Как это работает?
                </h6>
                <div class="small" style="color: var(--text-secondary) !important; line-height: 1.8;">
                    <p class="mb-2">
                        <span style="color: var(--color-green); font-weight: 600;">1.</span> Выберите <b>Категорию</b>.
                    </p>
                    <p class="mb-2">
                        <span style="color: var(--color-green); font-weight: 600;">2.</span> Система автоматически подставит <b>Критичность</b>.
                    </p>
                    <p class="mb-2">
                        <span style="color: var(--color-green); font-weight: 600;">3.</span> Заполните описание и ответственных.
                    </p>
                    <p class="mb-3">
                        <span style="color: var(--color-green); font-weight: 600;">4.</span> Нажмите "Создать" или "Сохранить".
                    </p>
                </div>
                
                <hr style="border-color: var(--color-green); opacity: 0.3;" />
                
                <div class="alert" style="background: rgba(0, 255, 0, 0.05) !important; border: 1px solid var(--color-green) !important; color: var(--color-green) !important;">
                    <i class="bi bi-info-circle"></i>
                    <b>Совет:</b> Для критических инцидентов срок решения — 1 час.
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private bool IsEdit => Id > 0;

    private Incident incident = new();
    private IEnumerable<Category> categories = new List<Category>();
    private IEnumerable<User> users = new List<User>();
    private bool showHint = false;

    protected override async Task OnInitializedAsync()
    {
        categories = await CategoryRepository.GetAllAsync();
        users = await UserRepository.GetAllAsync();

        if (IsEdit)
        {
            var existing = await IncidentService.GetIncidentByIdAsync(Id);
            if (existing != null)
            {
                incident = existing;
                showHint = true; // Чтобы показать подсказку при загрузке существующего
            }
            else
            {
                NavigationManager.NavigateTo("/incidents");
            }
        }
    }

    private void OnCategorySelected()
    {
        if (incident.CategoryId > 0)
        {
            var category = categories.FirstOrDefault(c => c.Id == incident.CategoryId);
            if (category != null)
            {
                incident.Severity = SeverityCalculator.CalculateSeverity(category);
                showHint = true;
                StateHasChanged();
            }
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            if (IsEdit)
            {
                await IncidentService.UpdateIncidentAsync(incident);
            }
            else
            {
                incident.ReportedDate = DateTime.UtcNow;
                await IncidentService.CreateIncidentAsync(incident);
            }
            
            NavigationManager.NavigateTo("/incidents");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка сохранения: {ex.Message}");
        }
    }
}